# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/compliance_db

# Redis (Upstash — use rediss:// for TLS)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 / S3-compatible storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET_NAME=multimodal-compliance
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Google Gemini VLM
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# OCR engine: auto | tesseract | surya
OCR_ENGINE=auto
SURYA_ENABLED=false

# API security (leave blank = open for demo)
API_KEY=

# Processing limits
MAX_FILE_SIZE_MB=20
MAX_PAGES=10
VIDEO_MAX_SECONDS=60
VLM_RATE_LIMIT_SLEEP=4.0

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_API_KEY=
